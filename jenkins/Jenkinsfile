pipeline {
    agent any

    environment {
        AWS_REGION       = 'us-east-1'
        ECR_REGISTRY     = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        EKS_CLUSTER_NAME = 'shopnest-production'
        NAMESPACE        = 'shopnest'
        IMAGE_TAG        = "${env.BUILD_NUMBER}-${env.GIT_COMMIT?.take(7) ?: 'latest'}"
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 60, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    stages {
        // ─── Stage 1: Checkout ─────────────────────────────────
        stage('Checkout') {
            steps {
                checkout scm
                script {
                    env.GIT_COMMIT_MSG = sh(script: "git log -1 --pretty=%B", returnStdout: true).trim()
                    env.GIT_AUTHOR    = sh(script: "git log -1 --pretty=%an", returnStdout: true).trim()
                }
                echo "📥 Building commit: ${env.GIT_COMMIT_MSG} by ${env.GIT_AUTHOR}"
            }
        }

        // ─── Stage 2: Install Dependencies ────────────────────
        stage('Install Dependencies') {
            parallel {
                stage('Frontend') {
                    steps {
                        dir('frontend') {
                            sh 'npm ci --silent'
                        }
                    }
                }
                stage('API Gateway') {
                    steps {
                        dir('api-gateway') {
                            sh 'npm ci --silent'
                        }
                    }
                }
                stage('User Service') {
                    steps {
                        dir('user-service') {
                            sh 'npm ci --silent'
                        }
                    }
                }
                stage('Product Service') {
                    steps {
                        dir('product-service') {
                            sh 'npm ci --silent'
                        }
                    }
                }
                stage('Order Service') {
                    steps {
                        dir('order-service') {
                            sh 'npm ci --silent'
                        }
                    }
                }
                stage('Payment Service') {
                    steps {
                        dir('payment-service') {
                            sh 'npm ci --silent'
                        }
                    }
                }
                stage('Notification Service') {
                    steps {
                        dir('notification-service') {
                            sh 'npm ci --silent'
                        }
                    }
                }
            }
        }

        // ─── Stage 3: Lint & Test ──────────────────────────────
        stage('Lint & Test') {
            parallel {
                stage('Frontend Tests') {
                    steps {
                        dir('frontend') {
                            sh 'npm test -- --watchAll=false --ci --coverage || true'
                        }
                    }
                    post {
                        always {
                            publishHTML(target: [
                                reportDir: 'frontend/coverage/lcov-report',
                                reportFiles: 'index.html',
                                reportName: 'Frontend Coverage'
                            ])
                        }
                    }
                }
                stage('User Service Tests') {
                    steps {
                        dir('user-service') {
                            sh 'npm test -- --coverage || true'
                        }
                    }
                }
                stage('Product Service Tests') {
                    steps {
                        dir('product-service') {
                            sh 'npm test -- --coverage || true'
                        }
                    }
                }
                stage('Order Service Tests') {
                    steps {
                        dir('order-service') {
                            sh 'npm test -- --coverage || true'
                        }
                    }
                }
            }
        }

        // ─── Stage 4: Security Scan ────────────────────────────
        stage('Security Scan') {
            steps {
                echo '🔒 Running npm audit...'
                sh '''
                    for svc in frontend api-gateway user-service product-service order-service payment-service notification-service; do
                        echo "Auditing $svc..."
                        cd $svc && npm audit --audit-level=high || true && cd ..
                    done
                '''
            }
        }

        // ─── Stage 5: Build Docker Images ─────────────────────
        stage('Build Docker Images') {
            steps {
                script {
                    def services = [
                        'frontend',
                        'api-gateway',
                        'user-service',
                        'product-service',
                        'order-service',
                        'payment-service',
                        'notification-service',
                    ]

                    parallel services.collectEntries { svc ->
                        ["Build ${svc}": {
                            sh """
                                echo "🐳 Building ${svc}..."
                                docker build \
                                    --build-arg BUILD_DATE=\$(date -u +'%Y-%m-%dT%H:%M:%SZ') \
                                    --build-arg VCS_REF=${env.GIT_COMMIT} \
                                    --build-arg VERSION=${IMAGE_TAG} \
                                    -t ${ECR_REGISTRY}/shopnest-${svc}:${IMAGE_TAG} \
                                    -t ${ECR_REGISTRY}/shopnest-${svc}:latest \
                                    ./${svc}
                                echo "✅ ${svc} built successfully"
                            """
                        }]
                    }
                }
            }
        }

        // ─── Stage 6: Push to AWS ECR ─────────────────────────
        stage('Push to AWS ECR') {
            steps {
                script {
                    withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-credentials']]) {
                        // Login to ECR
                        sh """
                            aws ecr get-login-password --region ${AWS_REGION} | \
                            docker login --username AWS --password-stdin ${ECR_REGISTRY}
                        """

                        def services = [
                            'frontend', 'api-gateway', 'user-service',
                            'product-service', 'order-service', 'payment-service',
                            'notification-service',
                        ]

                        parallel services.collectEntries { svc ->
                            ["Push ${svc}": {
                                sh """
                                    echo "📤 Pushing shopnest-${svc}:${IMAGE_TAG}..."
                                    docker push ${ECR_REGISTRY}/shopnest-${svc}:${IMAGE_TAG}
                                    docker push ${ECR_REGISTRY}/shopnest-${svc}:latest
                                    echo "✅ ${svc} pushed"
                                """
                            }]
                        }
                    }
                }
            }
        }

        // ─── Stage 7: Update K8s Image Tags ───────────────────
        stage('Update Kubernetes Manifests') {
            steps {
                script {
                    sh """
                        sed -i 's|\${ECR_REGISTRY}|${ECR_REGISTRY}|g' kubernetes/deployments/services.yaml
                    """
                }
            }
        }

        // ─── Stage 8: Deploy to EKS ───────────────────────────
        stage('Deploy to EKS') {
            when {
                anyOf {
                    branch 'main'
                    branch 'production'
                }
            }
            steps {
                script {
                    withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-credentials']]) {
                        sh """
                            # Update kubeconfig
                            aws eks update-kubeconfig \
                                --region ${AWS_REGION} \
                                --name ${EKS_CLUSTER_NAME}

                            # Apply namespace and configs
                            kubectl apply -f kubernetes/configmaps/
                            kubectl apply -f kubernetes/secrets/ --dry-run=client

                            # Deploy services
                            kubectl apply -f kubernetes/deployments/services.yaml -n ${NAMESPACE}
                            kubectl apply -f kubernetes/services/services.yaml -n ${NAMESPACE}
                            kubectl apply -f kubernetes/ingress/ingress.yaml -n ${NAMESPACE}
                            kubectl apply -f kubernetes/hpa/hpa.yaml -n ${NAMESPACE}

                            # Update image tags for each service
                            for svc in api-gateway user-service product-service order-service payment-service notification-service frontend; do
                                kubectl set image deployment/\$svc \
                                    \$svc=${ECR_REGISTRY}/shopnest-\$svc:${IMAGE_TAG} \
                                    -n ${NAMESPACE} || true
                            done

                            # Wait for rollout
                            echo "⏳ Waiting for rollout..."
                            kubectl rollout status deployment/api-gateway -n ${NAMESPACE} --timeout=5m
                            kubectl rollout status deployment/user-service -n ${NAMESPACE} --timeout=5m
                            kubectl rollout status deployment/product-service -n ${NAMESPACE} --timeout=5m
                            kubectl rollout status deployment/order-service -n ${NAMESPACE} --timeout=5m

                            echo "✅ Deployment complete!"
                        """
                    }
                }
            }
        }

        // ─── Stage 9: Smoke Tests ──────────────────────────────
        stage('Smoke Tests') {
            when { branch 'main' }
            steps {
                script {
                    withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-credentials']]) {
                        sh """
                            # Get the API Gateway external IP
                            API_URL=\$(kubectl get service api-gateway \
                                -n ${NAMESPACE} \
                                -o jsonpath='{.status.loadBalancer.ingress[0].hostname}' 2>/dev/null || echo "localhost:8080")

                            echo "🧪 Running smoke tests against http://\$API_URL"

                            # Health checks
                            for endpoint in health api/users/health api/products/health; do
                                STATUS=\$(curl -s -o /dev/null -w "%{http_code}" http://\$API_URL/\$endpoint || echo "000")
                                if [ "\$STATUS" = "200" ]; then
                                    echo "✅ /\$endpoint → OK"
                                else
                                    echo "⚠️  /\$endpoint → HTTP \$STATUS"
                                fi
                            done
                        """
                    }
                }
            }
        }
    }

    // ─── Post Actions ──────────────────────────────────────────
    post {
        success {
            echo "🎉 Pipeline succeeded! Build #${env.BUILD_NUMBER} deployed."
            // Slack notification (configure webhook in Jenkins credentials)
            // slackSend(color: 'good', message: "✅ ShopNest deployed successfully! Build #${env.BUILD_NUMBER}")
        }
        failure {
            echo "❌ Pipeline failed! Build #${env.BUILD_NUMBER}"
            // slackSend(color: 'danger', message: "❌ ShopNest deployment failed! Build #${env.BUILD_NUMBER}")
        }
        always {
            // Clean up Docker images to save disk space
            sh '''
                docker image prune -f --filter "until=24h" || true
            '''
            cleanWs()
        }
    }
}